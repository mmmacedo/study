{
  "info": {
    "_postman_id": "stream-service-collection",
    "name": "stream-service — Smoke Tests",
    "description": "Smoke tests isolados do stream-service. Executado pelo Newman no pipeline isolado jenkins/pipelines/stream-service.Jenkinsfile.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8083" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health — UP",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        },
        {
          "name": "GET /actuator/health/liveness — UP",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health/liveness"
          }
        },
        {
          "name": "GET /actuator/health/readiness — UP",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health/readiness"
          }
        }
      ]
    },
    {
      "name": "SSE Endpoint",
      "item": [
        {
          "name": "GET /stream/events — sem token → 401",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status 401 sem autenticação', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/event-stream" }],
            "url": "{{baseUrl}}/stream/events"
          }
        },
        {
          "name": "GET /stream/events — com token → 200 + text/event-stream",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('content-type SSE', () => {",
            "  pm.expect(pm.response.headers.get('content-type')).to.include('text/event-stream');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "text/event-stream" }
            ],
            "url": "{{baseUrl}}/stream/events"
          }
        }
      ]
    }
  ]
}
